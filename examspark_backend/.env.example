# ExamSpark — copy to .env (NEVER commit .env)
# Full guide: API_SETUP.md

SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase Dashboard -> Settings -> API -> JWT Settings -> "JWT Secret"
# (NOT the anon key or service role key) — used by FastAPI to verify the
# Authorization: Bearer <token> header on every protected route.
SUPABASE_JWT_SECRET=

GROQ_API_KEY=
GROQ_WHISPER_TURBO_MODEL=whisper-large-v3-turbo
GROQ_WHISPER_STANDARD_MODEL=whisper-large-v3

OPENROUTER_API_KEY=
AI_CHAT_MODEL=qwen/qwen3-30b-a3b-instruct-2507
AI_REASONING_MODEL=qwen/qwen3-235b-a22b-2507
AI_FALLBACK_MODEL=qwen/qwen3-30b-a3b-instruct-2507
# Session 3 RAG — must be 1536 dims (matches schema rag_documents.embedding)
AI_EMBEDDING_MODEL=openai/text-embedding-3-small
# Vision (TECH_STACK.md): Flash default; Plus only on auto-escalation.
# Same OPENROUTER_API_KEY — three model names, not three API subscriptions.
AI_VISION_FLASH_MODEL=qwen/qwen3-vl-8b-instruct
AI_VISION_PLUS_MODEL=qwen/qwen3-vl-235b-a22b-instruct
# Legacy alias — if set and FLASH unset, config falls back to this for Flash.
# AI_VISION_MODEL=

TAVILY_API_KEY=

CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# R2 = PERMANENT content storage (Transcript, Notes, Summary, key points,
# important terms — see r2_storage_service.py). NOT temporary audio staging —
# raw audio is never written here (see examspark-backend-engineering-rules.mdc
# Rule 3). Postgres stores only the R2 path string, never the content itself.
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_URL=

PGVECTOR_ENABLED=true

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

PHONEPE_MERCHANT_ID=
PHONEPE_SALT_KEY=
PHONEPE_SALT_INDEX=

# Google Play Billing (Android) — Live Store listing NOT required for Internal testing.
# GOOGLE_PLAY_PACKAGE_NAME must match Flutter applicationId (see FOUNDER_GOOGLE_PLAY_BILLING.md)
GOOGLE_PLAY_PACKAGE_NAME=com.example.examspark_frontend
# Path to service-account JSON file OR raw JSON string (Play Android Developer API)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=
GOOGLE_PLAY_LICENSE_KEY=

FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_APP_ID=
FIREBASE_MESSAGING_SENDER_ID=

RESEND_API_KEY=

POSTHOG_API_KEY=
POSTHOG_HOST=

JWT_SECRET=
ENCRYPTION_KEY=

FASTAPI_BASE_URL=http://localhost:8000
