# ExamSpark Flutter — copy to .env (NEVER commit .env)
# When to paste: ../ENV_PASTE_TIMELINE.md
# Full server keys: ../examspark_backend/.env.example
# Full key reference: ../API_SETUP.md
#
# Flutter uses ONLY client-safe keys below.
# Never put SUPABASE_SERVICE_ROLE_KEY, JWT_SECRET, or ENCRYPTION_KEY here.

# PASTE NOW (optional) — login test only
SUPABASE_URL=
SUPABASE_ANON_KEY=

# PHASE 5 — paste when running FastAPI locally
# FASTAPI_BASE_URL=http://localhost:8000
# Session 6 — public Key ID only (never KEY_SECRET in Flutter)
# RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
